# ─── Database ────────────────────────────────────
DATABASE_URL=postgresql://tokenvault:tokenvault_secret@localhost:5432/tokenvault

# ─── Redis ───────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Auth (generate a random secret for prod) ────
JWT_SECRET=supersecret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d

# ─── API Ports ───────────────────────────────────
API_PORT=3001
GATEWAY_PORT=8080

# ─── Frontend (public vars) ──────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_APP_NAME=TokenVault

# ─── Email (SendGrid) ────────────────────────────
SENDGRID_API_KEY=SG.your_key_here
FROM_EMAIL=noreply@tokenvault.ai

# ─── SMS (Twilio) ─────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxx
TWILIO_AUTH_TOKEN=your_twilio_token
TWILIO_PHONE_NUMBER=+1234567890

# ─── Encryption ──────────────────────────────────
ENCRYPTION_KEY=32-character-hex-key-here-change-me
